{
  "name": "win11-backend",
  "version": "0.1.0",
  "description": "Win11 fantasy sports backend — modular monolith (Node.js + Express + TypeScript + MongoDB + Redis + BullMQ + Socket.io).",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon",
    "build": "node ./node_modules/typescript/bin/tsc -p tsconfig.json --noCheck && node ./node_modules/tsc-alias/dist/bin/index.js -p tsconfig.json",
    "start": "node dist/server.js",
    "start:worker": "node dist/queues/worker.js",
    "lint": "eslint \"src/**/*.{ts,tsx}\" --max-warnings=0",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" --fix",
    "format": "prettier --write \"src/**/*.{ts,json,md}\"",
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:integration": "vitest run --config vitest.config.ts",
    "test:integration:watch": "vitest --config vitest.config.ts",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "seed:wallet": "ts-node -r tsconfig-paths/register --transpile-only src/seeds/wallet-credit.seed.ts",
    "seed:sports": "ts-node -r tsconfig-paths/register --transpile-only src/seeds/sports-catalogue.seed.ts",
    "prepare": "node -e \"if (process.env.CI || process.env.RENDER || process.env.NODE_ENV === 'production') process.exit(0); try { require('child_process').execSync('husky install', { stdio: 'inherit' }); } catch (_) { process.exit(0); }\""
  },
  "engines": {
    "node": "20.x",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "@socket.io/redis-adapter": "^8.3.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.12.0",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "hpp": "^0.2.3",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.5.1",
    "morgan": "^1.10.0",
    "pino": "^9.3.2",
    "pino-pretty": "^11.2.2",
    "rate-limit-redis": "^4.2.0",
    "socket.io": "^4.7.5",
    "stripe": "^22.3.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "tsc-alias": "^1.8.17",
    "typescript": "5.9.3",
    "uuid": "^10.0.0",
    "xss-clean": "^0.1.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/hpp": "^0.2.5",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.14.11",
    "@types/supertest": "^7.2.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.6",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.16.1",
    "@typescript-eslint/parser": "^7.16.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-typescript": "^3.10.1",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-prettier": "^5.1.3",
    "husky": "^9.1.1",
    "jest": "^29.7.0",
    "lint-staged": "^15.2.7",
    "nodemon": "^3.1.4",
    "prettier": "^3.3.3",
    "socket.io-client": "^4.7.5",
    "supertest": "^7.2.2",
    "ts-jest": "^29.2.3",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.9"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
