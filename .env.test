# Win11 Backend — integration test environment
# Loaded by tests/setup/env.ts with override=true before any app imports.

NODE_ENV=test
APP_NAME=Win11
APP_SLUG=win11
APP_DEFAULT_CURRENCY=INR
APP_DEFAULT_LOCALE=en-IN
PORT=4099
API_PREFIX=/api/v1
LOG_LEVEL=error

CORS_ORIGIN=http://localhost:5173
TRUST_PROXY=1

# Isolated test database (requires local replica set for transactions)
MONGO_URI=mongodb://localhost:27017/win11_test?replicaSet=rs0&directConnection=true
MONGO_MIN_POOL=2
MONGO_MAX_POOL=10

REDIS_URL=
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DB=1
REDIS_TLS=false
REDIS_KEY_PREFIX=win11:test:
REDIS_ENABLED=false
MANUAL_DEPOSIT_ENABLED=true
PAYMENT_PROVIDER=mock

JWT_ACCESS_SECRET=8f3a92e7d4b15c6e0a89f2db3147e8c95f6b1d2a4708c9e3f5a6b8c1d2e4f607
JWT_REFRESH_SECRET=4d7e1a6b3f9c2e58d0a47b1f6e9c8d3a5b2f7e0d8c4a1b9e3f6d2c5a8b7e0f12
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
JWT_ISSUER=win11
JWT_AUDIENCE=win11-mobile

# Relax rate limits so parallel assertions within a test file do not flake
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100000

BULLMQ_PREFIX=win11:test:bull

SOCKET_PATH=/socket.io
SOCKET_PING_INTERVAL=20000
SOCKET_PING_TIMEOUT=25000

ENABLE_SWAGGER=false
ENABLE_REQUEST_LOGS=false

CRIC_API_KEY=
CRIC_API_BASE_URL=https://api.cricapi.com/v1
CRIC_API_TIMEOUT_MS=8000
CRIC_API_SERIES_IDS=
