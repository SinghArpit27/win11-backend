# ───────────────────────────────────────────────────────────────────────────────
# Win11 Backend — environment variables example
# Copy to `.env` and fill actual values
# ───────────────────────────────────────────────────────────────────────────────

NODE_ENV=development

APP_NAME=Win11
APP_SLUG=win11
APP_TAGLINE=Fantasy Sports — Reimagined
APP_LOGO_URL=
APP_THEME=dark-fantasy
APP_DEFAULT_CURRENCY=INR
APP_DEFAULT_LOCALE=en-IN
APP_VERSION=0.1.0

PORT=4000
API_PREFIX=/api/v1
LOG_LEVEL=debug


# CORS
CORS_ORIGIN=http://localhost:5173,http://localhost:4173
TRUST_PROXY=1


# MongoDB
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/database

MONGO_MIN_POOL=5
MONGO_MAX_POOL=50


# Redis
REDIS_URL=
REDIS_HOST=
REDIS_PORT=
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS=true
REDIS_KEY_PREFIX=win11:

REDIS_ENABLED=false


# JWT
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

JWT_ISSUER=win11
JWT_AUDIENCE=win11-mobile


# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300


# BullMQ
BULLMQ_PREFIX=win11:bull


# Socket.io
SOCKET_PATH=/socket.io
SOCKET_PING_INTERVAL=20000
SOCKET_PING_TIMEOUT=25000


# Features
ENABLE_SWAGGER=true
ENABLE_REQUEST_LOGS=true



# Cricket API

CRIC_API_KEY=
CRIC_API_BASE_URL=https://api.cricapi.com/v1

CRIC_API_TIMEOUT_MS=8000
CRIC_API_SERIES_IDS=



# Stripe

PAYMENT_PROVIDER=stripe

STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

STRIPE_ENABLE_UPI=true
STRIPE_UPI_SIMULATOR=true

STRIPE_UPI_VPA=

FRONTEND_URL=http://localhost:5173

MANUAL_DEPOSIT_ENABLED=false